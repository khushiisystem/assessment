# Django settings
SECRET_KEY=dummy-secret-key-123456789
DEBUG=True
ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=https://dummy-domain.com

SITE_URL=https://dummy-domain.com

# Database
DB_ENGINE=django.db.backends.mysql
DB_NAME=app_db
DB_USER=mysql_user
DB_PASSWORD=Mysql@1234
DB_HOST=127.0.0.1
DB_PORT=3306

# Email configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=dummy.email@domain.com
EMAIL_HOST_PASSWORD=dummy-email-password
DEFAULT_FROM_EMAIL=Online Assessment <noreply@dummy.com>

# Judge0 API
JUDGE0_API_URL=https://ce.judge0.com
JUDGE0_API_KEY=dummy-judge0-key

# Time zone
TIME_ZONE=Asia/Kolkata

# Webhook secret
WEBHOOK_SECRET=dummy-webhook-secret-123456789

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=DUMMYAWSACCESSKEY12345
AWS_SECRET_ACCESS_KEY=DUMMYAWSSECRETACCESSKEY123456789
AWS_STORAGE_BUCKET_NAME=dummy-bucket
AWS_S3_REGION_NAME=ap-south-1
AWS_S3_SIGNATURE_VERSION=s3v4
USE_S3=True

# Google Vertex AI
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# Optional. If empty, Django also checks ../credentials/google-credentials.json.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/vertex-key.json
# CI/CD: store the full service-account JSON in a secret and expose it here.
GOOGLE_CREDENTIALS_JSON=

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
